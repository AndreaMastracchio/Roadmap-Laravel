# Configurazione Database (MariaDB)
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=laravelstudy
MYSQL_USER=laraveluser
MYSQL_PASSWORD=laravelpassword
MYSQL_HOST=laravelstudy-db

# Configurazione Redis
REDIS_HOST=laravelstudy-redis
REDIS_PORT=6379

# Configurazione Twilio (Opzionale - per invio SMS reali)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Configurazione Backend
PORT=5006
NODE_ENV=development
SESSION_SECRET=cambiami_in_produzione_laravel_123456

# Configurazione Frontend (Vite)
VITE_API_URL=http://localhost:5006/api

# Percorsi Progetti (Corsi)
PROJECT_PUBLIC_PATH=./project_public
PROJECT_PRIVATE_PATH=./project_private
